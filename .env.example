# Copy this file to .env.local for local development
# For Vercel deployment, set these as environment variables in the Vercel dashboard

# Telegram Bot Token (get from @BotFather)
REACT_APP_TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (your user ID or group ID)
REACT_APP_TELEGRAM_CHAT_ID=your_chat_id_here

# Backend URL (for production, this will be /api/send-to-telegram)
REACT_APP_BACKEND_URL=/api/send-to-telegram

# Optional: Enable debug mode
REACT_APP_DEBUG=true